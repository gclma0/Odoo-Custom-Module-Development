<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_incoming_fund_tree" model="ir.ui.view">
        <field name="name">nn.incoming.fund.tree</field>
        <field name="model">nn.incoming.fund</field>
        <field name="arch" type="xml">
            <tree string="Incoming Funds">
                <field name="date" />
                <field name="transaction_reference" />
                <field name="fund_account_id" />
                <field name="sender_source" />
                <field name="amount" />
                <field name="company_id" groups="base.group_multi_company" />
                <field name="state" widget="badge" decoration-success="state == 'confirmed'" decoration-warning="state == 'draft'" decoration-danger="state == 'cancelled'" />
            </tree>
        </field>
    </record>

    <record id="view_nn_incoming_fund_form" model="ir.ui.view">
        <field name="name">nn.incoming.fund.form</field>
        <field name="model">nn.incoming.fund</field>
        <field name="arch" type="xml">
            <form string="Incoming Fund">
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary" invisible="state != 'draft'" groups="nn_fund_management.group_finance_user,nn_fund_management.group_fund_administrator" />
                    <button name="action_cancel" type="object" string="Cancel" invisible="state != 'draft'" groups="nn_fund_management.group_finance_user,nn_fund_management.group_fund_administrator" />
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft" invisible="state != 'cancelled'" groups="nn_fund_management.group_finance_user,nn_fund_management.group_fund_administrator" />
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,cancelled" />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="fund_account_id" readonly="state != 'draft'" />
                            <field name="date" readonly="state != 'draft'" />
                            <field name="amount" readonly="state != 'draft'" />
                            <field name="currency_id" readonly="1" />
                        </group>
                        <group>
                            <field name="transaction_reference" readonly="state != 'draft'" />
                            <field name="sender_source" readonly="state != 'draft'" />
                            <field name="company_id" groups="base.group_multi_company" readonly="1" />
                        </group>
                    </group>
                    <group string="Supporting Information">
                        <field name="description" readonly="state != 'draft'" placeholder="Reference details or notes about the source of funds." />
                        <field name="attachment_filename" invisible="1" />
                        <field name="attachment" filename="attachment_filename" readonly="state != 'draft'" />
                    </group>
                    <group string="Confirmation Details" invisible="state == 'draft'">
                        <field name="confirmed_by" readonly="1" />
                        <field name="confirmed_date" readonly="1" />
                    </group>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="view_nn_incoming_fund_search" model="ir.ui.view">
        <field name="name">nn.incoming.fund.search</field>
        <field name="model">nn.incoming.fund</field>
        <field name="arch" type="xml">
            <search string="Incoming Funds">
                <field name="transaction_reference" />
                <field name="fund_account_id" />
                <field name="sender_source" />
                <field name="state" />
                <field name="company_id" groups="base.group_multi_company" />
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]" />
                <filter name="filter_confirmed" string="Confirmed" domain="[('state', '=', 'confirmed')]" />
                <filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]" />
                <group expand="0" string="Group By">
                    <filter name="group_by_account" string="Fund Account" context="{'group_by': 'fund_account_id'}" />
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}" />
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}" groups="base.group_multi_company" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_nn_incoming_fund" model="ir.actions.act_window">
        <field name="name">Incoming Funds</field>
        <field name="res_model">nn.incoming.fund</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_nn_incoming_fund_search" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Record your first incoming fund</p>
            <p>
                Confirmed incoming funds increase the selected fund account's total received and available unassigned balance.
            </p>
        </field>
    </record>
</odoo>
