<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_project_form_inherit_nn_fund_management" model="ir.ui.view">
        <field name="name">project.project.form.inherit.nn.fund.management</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project" />
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Fund Management">
                    <group string="Configuration">
                        <field name="fund_category" />
                    </group>
                    <group string="Balance Overview" col="4">
                        <field name="total_allocated_fund" readonly="1" />
                        <field name="available_fund" readonly="1" />
                        <field name="requisition_hold" readonly="1" />
                        <field name="transfer_hold" readonly="1" />
                        <field name="approved_unspent_amount" readonly="1" />
                        <field name="total_spent_amount" readonly="1" />
                        <field name="incoming_transfer_amount" readonly="1" />
                        <field name="outgoing_transfer_amount" readonly="1" />
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
