<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_expense_head_tree" model="ir.ui.view">
        <field name="name">nn.expense.head.tree</field>
        <field name="model">nn.expense.head</field>
        <field name="arch" type="xml">
            <tree string="Expense Heads">
                <field name="name" />
                <field name="code" />
                <field name="company_id" groups="base.group_multi_company" />
                <field name="available_fund" />
                <field name="requisition_hold" />
                <field name="transfer_hold" />
                <field name="total_spent_amount" />
                <field name="active" optional="hide" />
            </tree>
        </field>
    </record>

    <record id="view_nn_expense_head_form" model="ir.ui.view">
        <field name="name">nn.expense.head.form</field>
        <field name="model">nn.expense.head</field>
        <field name="arch" type="xml">
            <form string="Expense Head">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active" />
                    <group>
                        <group>
                            <field name="name" />
                            <field name="code" />
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company" />
                            <field name="currency_id" readonly="1" />
                            <field name="active" />
                        </group>
                    </group>
                    <group string="Balance Overview" col="4">
                        <field name="total_allocated_fund" readonly="1" />
                        <field name="available_fund" readonly="1" />
                        <field name="requisition_hold" readonly="1" />
                        <field name="transfer_hold" readonly="1" />
                        <field name="approved_unspent_amount" readonly="1" />
                        <field name="total_spent_amount" readonly="1" />
                        <field name="incoming_transfer_amount" readonly="1" />
                        <field name="outgoing_transfer_amount" readonly="1" />
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="description" placeholder="Internal notes about this expense head." />
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="view_nn_expense_head_search" model="ir.ui.view">
        <field name="name">nn.expense.head.search</field>
        <field name="model">nn.expense.head</field>
        <field name="arch" type="xml">
            <search string="Expense Heads">
                <field name="name" />
                <field name="code" />
                <field name="company_id" groups="base.group_multi_company" />
                <filter name="filter_active" string="Active" domain="[('active', '=', True)]" />
                <filter name="filter_archived" string="Archived" domain="[('active', '=', False)]" />
                <group expand="0" string="Group By">
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}" groups="base.group_multi_company" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_nn_expense_head" model="ir.actions.act_window">
        <field name="name">Expense Heads</field>
        <field name="res_model">nn.expense.head</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_nn_expense_head_search" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first expense head</p>
            <p>
                Expense heads represent non-project fund destinations such as salary, rent, utility, or marketing.
            </p>
        </field>
    </record>
</odoo>
