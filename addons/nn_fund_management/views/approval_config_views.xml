<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_approval_config_tree" model="ir.ui.view">
        <field name="name">nn.approval.config.tree</field>
        <field name="model">nn.approval.config</field>
        <field name="arch" type="xml">
            <tree string="Approval Configurations">
                <field name="name" />
                <field name="request_type" />
                <field name="project_id" optional="hide" />
                <field name="expense_head_id" optional="hide" />
                <field name="company_id" groups="base.group_multi_company" />
                <field name="min_amount" />
                <field name="max_amount" />
                <field name="active" optional="hide" />
            </tree>
        </field>
    </record>

    <record id="view_nn_approval_config_form" model="ir.ui.view">
        <field name="name">nn.approval.config.form</field>
        <field name="model">nn.approval.config</field>
        <field name="arch" type="xml">
            <form string="Approval Configuration">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active" />
                    <group>
                        <group>
                            <field name="name" />
                            <field name="request_type" />
                            <field name="company_id" groups="base.group_multi_company" />
                        </group>
                        <group>
                            <field name="currency_id" readonly="1" />
                            <field name="min_amount" />
                            <field name="max_amount" />
                            <field name="active" />
                        </group>
                    </group>
                    <group string="Optional Target Filter">
                        <field name="project_id" invisible="expense_head_id" />
                        <field name="expense_head_id" invisible="project_id" />
                    </group>
                    <notebook>
                        <page string="Approval Steps">
                            <field name="line_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle" />
                                    <field name="approval_level" />
                                    <field name="approver_user_id" />
                                    <field name="approver_group_id" />
                                    <field name="required" />
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="Optional notes about when this approval rule should be used." />
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="view_nn_approval_config_search" model="ir.ui.view">
        <field name="name">nn.approval.config.search</field>
        <field name="model">nn.approval.config</field>
        <field name="arch" type="xml">
            <search string="Approval Configurations">
                <field name="name" />
                <field name="request_type" />
                <field name="company_id" groups="base.group_multi_company" />
                <filter name="filter_active" string="Active" domain="[('active', '=', True)]" />
                <filter name="filter_archived" string="Archived" domain="[('active', '=', False)]" />
                <group expand="0" string="Group By">
                    <filter name="group_by_request_type" string="Request Type" context="{'group_by': 'request_type'}" />
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}" groups="base.group_multi_company" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_nn_approval_config" model="ir.actions.act_window">
        <field name="name">Approval Configurations</field>
        <field name="res_model">nn.approval.config</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_nn_approval_config_search" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first approval configuration</p>
            <p>
                Use approval configurations to define who approves allocations, requisitions, and transfers without hardcoding approvers.
            </p>
        </field>
    </record>
</odoo>
