<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_fund_allocation_tree" model="ir.ui.view">
        <field name="name">nn.fund.allocation.tree</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <tree string="Fund Allocations">
                <field name="request_number" />
                <field name="request_date" />
                <field name="fund_account_id" />
                <field name="project_id" optional="show" />
                <field name="expense_head_id" optional="show" />
                <field name="requested_by" />
                <field name="amount" />
                <field name="state" widget="badge" decoration-warning="state in ('submitted', 'gm_approval', 'finance_approval', 'md_approval')" decoration-success="state == 'approved'" decoration-danger="state in ('rejected', 'cancelled', 'reversed')" />
            </tree>
        </field>
    </record>

    <record id="view_nn_fund_allocation_form" model="ir.ui.view">
        <field name="name">nn.fund.allocation.form</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <form string="Fund Allocation">
                <header>
                    <button name="action_submit" type="object" string="Submit" class="btn-primary" invisible="state != 'draft'" groups="nn_fund_management.group_fund_user,nn_fund_management.group_fund_administrator" />
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="not current_user_can_approve" groups="nn_fund_management.group_finance_user,nn_fund_management.group_gm_approver,nn_fund_management.group_md_approver,nn_fund_management.group_fund_administrator" />
                    <button name="action_reject" type="object" string="Reject" invisible="not current_user_can_approve" groups="nn_fund_management.group_finance_user,nn_fund_management.group_gm_approver,nn_fund_management.group_md_approver,nn_fund_management.group_fund_administrator" />
                    <button name="action_reverse" type="object" string="Reverse" invisible="state != 'approved'" groups="nn_fund_management.group_finance_user,nn_fund_management.group_fund_administrator" />
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ('approved', 'cancelled')" groups="nn_fund_management.group_fund_user,nn_fund_management.group_fund_administrator" />
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft" invisible="state not in ('rejected', 'cancelled')" groups="nn_fund_management.group_fund_user,nn_fund_management.group_fund_administrator" />
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,gm_approval,finance_approval,md_approval,approved,rejected,cancelled,reversed" />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="request_number" readonly="1" />
                            <field name="fund_account_id" readonly="state != 'draft'" />
                            <field name="request_date" readonly="state != 'draft'" />
                            <field name="amount" readonly="state != 'draft'" />
                        </group>
                        <group>
                            <field name="requested_by" readonly="1" />
                            <field name="company_id" groups="base.group_multi_company" readonly="1" />
                            <field name="currency_id" readonly="1" />
                            <field name="approval_config_id" readonly="1" invisible="not approval_config_id" />
                            <field name="current_user_can_approve" invisible="1" />
                        </group>
                    </group>
                    <group string="Allocation Target">
                        <field name="project_id" readonly="state != 'draft'" invisible="expense_head_id" />
                        <field name="expense_head_id" readonly="state != 'draft'" invisible="project_id" />
                    </group>
                    <group string="Purpose and Attachment">
                        <field name="purpose" readonly="state != 'draft'" placeholder="Explain why this allocation is needed." />
                        <field name="attachment_filename" invisible="1" />
                        <field name="attachment" filename="attachment_filename" readonly="state != 'draft'" />
                    </group>
                    <group string="Approval">
                        <field name="current_approval_line_id" readonly="1" invisible="state in ('draft', 'approved', 'rejected', 'cancelled')" />
                        <field name="approval_comment" placeholder="Optional approval or rejection comment." />
                    </group>
                    <notebook>
                        <page string="Approval History">
                            <field name="approval_history_ids" readonly="1">
                                <tree create="0" edit="0" delete="0">
                                    <field name="action_date" />
                                    <field name="approval_level" />
                                    <field name="decision" />
                                    <field name="action_by" />
                                    <field name="old_state" />
                                    <field name="new_state" />
                                    <field name="comment" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="view_nn_fund_allocation_search" model="ir.ui.view">
        <field name="name">nn.fund.allocation.search</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <search string="Fund Allocations">
                <field name="request_number" />
                <field name="fund_account_id" />
                <field name="project_id" />
                <field name="expense_head_id" />
                <field name="requested_by" />
                <field name="state" />
                <filter name="filter_pending" string="Pending Approval" domain="[('state', 'in', ('submitted', 'gm_approval', 'finance_approval', 'md_approval'))]" />
                <filter name="filter_approved" string="Approved" domain="[('state', '=', 'approved')]" />
                <filter name="filter_rejected" string="Rejected" domain="[('state', '=', 'rejected')]" />
                <filter name="filter_reversed" string="Reversed" domain="[('state', '=', 'reversed')]" />
                <group expand="0" string="Group By">
                    <filter name="group_by_account" string="Fund Account" context="{'group_by': 'fund_account_id'}" />
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}" />
                    <filter name="group_by_requester" string="Requested By" context="{'group_by': 'requested_by'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_nn_fund_allocation" model="ir.actions.act_window">
        <field name="name">Fund Allocations</field>
        <field name="res_model">nn.fund.allocation</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_nn_fund_allocation_search" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first fund allocation</p>
            <p>
                Allocate money from a fund account to either a project or an expense head. Pending allocations hold the amount until approval is completed.
            </p>
        </field>
    </record>
</odoo>
