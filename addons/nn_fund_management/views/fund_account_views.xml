<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nn_fund_account_list" model="ir.ui.view">
        <field name="name">nn.fund.account.list</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <tree string="Fund Accounts">
                <field name="name" />
                <field name="code" />
                <field name="account_type" />
                <field name="company_id" groups="base.group_multi_company" />
                <field name="currency_id" optional="hide" />
                <field name="available_unassigned_balance" />
                <field name="amount_on_hold" />
                <field name="total_assigned_amount" />
                <field name="active" optional="hide" />
            </tree>
        </field>
    </record>

    <record id="view_nn_fund_account_form" model="ir.ui.view">
        <field name="name">nn.fund.account.form</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <form string="Fund Account">
                <sheet>
                    <div class="oe_button_box" name="button_box" />
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active" />
                    <group>
                        <group>
                            <field name="name" />
                            <field name="code" />
                            <field name="account_type" />
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company" />
                            <field name="currency_id" readonly="1" />
                            <field name="active" />
                        </group>
                    </group>

                    <group string="Balance Overview" col="4">
                        <field name="total_received" readonly="1" />
                        <field name="available_unassigned_balance" readonly="1" />
                        <field name="amount_on_hold" readonly="1" />
                        <field name="total_assigned_amount" readonly="1" />
                    </group>

                    <notebook>
                        <page string="Notes">
                            <field name="description" placeholder="Internal notes about this fund account." />
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="view_nn_fund_account_search" model="ir.ui.view">
        <field name="name">nn.fund.account.search</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <search string="Fund Accounts">
                <field name="name" />
                <field name="code" />
                <field name="account_type" />
                <field name="company_id" groups="base.group_multi_company" />
                <filter name="filter_active" string="Active" domain="[('active', '=', True)]" />
                <filter name="filter_archived" string="Archived" domain="[('active', '=', False)]" />
                <group expand="0" string="Group By">
                    <filter name="group_by_type" string="Account Type" context="{'group_by': 'account_type'}" />
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}" groups="base.group_multi_company" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_nn_fund_account" model="ir.actions.act_window">
        <field name="name">Fund Accounts</field>
        <field name="res_model">nn.fund.account</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_nn_fund_account_search" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first fund account</p>
            <p>
                Fund accounts represent the bank, cash, or other sources where incoming funds are received.
            </p>
        </field>
    </record>
</odoo>
