<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_nn_fund_account_company" model="ir.rule">
        <field name="name">Fund Account Company Access</field>
        <field name="model_id" ref="model_nn_fund_account" />
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('nn_fund_management.group_fund_user'))]" />
    </record>

